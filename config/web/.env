# 默认环境（VUE_APP_* 才会被 Vue CLI 暴露到 process.env.VUE_APP_*）
# 真实部署值见 config/web/.env.production；本机开发用 config/web/.env.development。

VUE_APP_NAME=phone-analysis 可视化看板
VUE_APP_API_BASE=/api
VUE_APP_DEV_PORT=8081
VUE_APP_API_PROXY=http://phone-analysis:8080
VUE_APP_DASHBOARD_REFRESH_MS=600000
VUE_APP_ALERT_MAX_HISTORY=100
